# Required
OPENROUTER_API_KEY=sk-or-v1-...

# ---------------------------------------------------------------------------
# Model tiers — OS/hardware analogy
# Drop the "openrouter/" prefix when calling openrouter.ai/api/v1 directly
# ---------------------------------------------------------------------------

# NANO — microcontroller / background thread
# Used for ALL routing calls and deterministic-skill fallbacks.
# Cheapest possible; runs constantly in the background.
# Default: google/gemini-2.5-flash-lite ($0.18/M blended, 1M ctx)
# Alternatives:
#   openai/gpt-5-nano           ($0.14/M, 128K)
#   deepseek/deepseek-v3.2      ($0.31/M, 164K)
#   openai/gpt-5-mini           ($0.69/M, 128K)
# MACROA_MODEL_NANO=google/gemini-2.5-flash-lite

# HAIKU — efficiency cores / E-cores
# First escalation target; handles lightweight tasks that need a real LLM.
# Default: anthropic/claude-haiku-4-5 ($2.00/M blended, 200K ctx)
# Alternatives:
#   google/gemini-2.5-flash     ($0.85/M, 1M)
#   minimax/minimax-m2.5        ($0.53/M, 205K)
#   moonshotai/kimi-k2.5        ($1.08/M, 262K)
#   z-ai/glm-5                  ($1.35/M, 205K)
# MACROA_MODEL_HAIKU=anthropic/claude-haiku-4-5

# SONNET — performance cores / P-cores
# Quality work; triggered by "think carefully", escalation from HAIKU, or skill pin.
# Default: anthropic/claude-sonnet-4-6 ($6.00/M blended, 1M ctx)
# MACROA_MODEL_SONNET=anthropic/claude-sonnet-4-6

# OPUS — GPU
# Heavy reasoning; most resource-intensive, use sparingly.
# Triggered by "opus", "best model", "use the gpu", or two failed escalations.
# Default: anthropic/claude-opus-4-6 ($10.00/M blended, 1M ctx)
# Alternatives:
#   openai/gpt-5                ($3.44/M, 400K)
# MACROA_MODEL_OPUS=anthropic/claude-opus-4-6

# ---------------------------------------------------------------------------

# Context window size (turns kept in rolling buffer)
# MACROA_CONTEXT_WINDOW=20

# Memory backend — sqlite (default) or json
# MACROA_MEMORY_BACKEND=sqlite

# Path to SQLite DB (default: ~/.macroa/memory.db)
# MACROA_MEMORY_DB_PATH=~/.macroa/memory.db

# OpenRouter analytics headers
# MACROA_HTTP_REFERER=https://github.com/yourname/macroa
# MACROA_APP_TITLE=Macroa

# ---------------------------------------------------------------------------
# Tools — userspace programs
# ---------------------------------------------------------------------------

# Directory where user-installed tools live
# Install a tool: cp -r my_tool/ ~/.macroa/tools/
# Default: ~/.macroa/tools/
# MACROA_TOOLS_DIR=~/.macroa/tools

# Heartbeat interval for persistent tools (seconds)
# Persistent tools have manifest.persistent=True and implement heartbeat()
# Default: 60
# MACROA_HEARTBEAT_INTERVAL=60
